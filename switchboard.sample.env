# switchboard.sample.env - Sample environment variables for switchboard configuration
#
# Copy this file to switchboard.env and fill in your actual values.
# DO NOT commit switchboard.env to version control - it's already in .gitignore
#
# Usage in switchboard.toml:
#   token_env = "${DISCORD_TOKEN}"        # Reads from DISCORD_TOKEN env var
#   api_key_env = "${OPENROUTER_API_KEY}"  # Reads from OPENROUTER_API_KEY env var
#
# You can also use default values:
#   token_env = "${DISCORD_TOKEN:-}"      # Uses empty string if DISCORD_TOKEN not set
#   api_key_env = "${OPENROUTER_API_KEY:-default_key}"  # Uses "default_key" if not set

# Discord Bot Configuration
DISCORD_TOKEN=your-discord-token-here
DISCORD_CHANNEL_ID=your-discord-channel-id-here

# OpenRouter LLM Configuration
OPENROUTER_API_KEY=your-openrouter-key-here
